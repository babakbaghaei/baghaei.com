// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  password         String
  name             String?
  role             Role     @default(USER)
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([role])
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String
  content     String?
  imageUrl    String?
  tags        String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, createdAt])
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([isRead, createdAt])
}

model JobApplication {
  id           Int      @id @default(autoincrement())
  position     String
  name         String
  email        String
  phone        String?
  portfolioUrl String?
  message      String?
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([isRead, createdAt])
}

model Service {
  id          Int      @id @default(autoincrement())
  order       Int      @default(0)
  title       String   @unique
  description String
  iconName    String   // Lucide icon name string
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, order])
}

// دیدگاه و امتیاز کاربران روی هر ابزارِ جعبه‌ابزار. عمومی است (approved=true
// پیش‌فرض)؛ ادمین می‌تواند مخفی/حذف کند. toolSlug همان اسلاگِ صفحهٔ ابزار است.
model ToolReview {
  id        Int      @id @default(autoincrement())
  toolSlug  String
  name      String?
  rating    Int
  body      String?
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([toolSlug, approved, createdAt])
}

// گزارش مشکل/خطای یک ابزار — از پنل داخل صفحه (نه ایمیل). به تلگرام هشدار می‌دهد.
model ToolReport {
  id        Int      @id @default(autoincrement())
  toolSlug  String
  issue     String
  contact   String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([toolSlug, createdAt])
  @@index([resolved, createdAt])
}

enum Role {
  USER
  ADMIN
}
