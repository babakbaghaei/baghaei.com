# Compiled output
/dist
/node_modules
/build

# Logs
/logs
*.log
npm-debug.log*

# Keep environment variables out of version control
.env

# Prisma
/generated/prisma
/prisma/*.db
/prisma/*.db-journal
# NOTE: prisma/migrations/ MUST be tracked — `prisma migrate deploy` (CI + container entrypoint) needs the files.
