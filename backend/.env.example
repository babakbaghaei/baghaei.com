# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/baghaei_db?schema=public"

# App
PORT=8000
NODE_ENV=development

# Security
JWT_SECRET="your-super-secret-key-change-this-in-production"

# Notifications (Telegram)
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

# Notifications (Email — optional; all four required to enable email channel)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""              # optional, defaults to SMTP_USER
CONTACT_NOTIFY_EMAIL=""   # optional, where contact emails are sent (defaults to SMTP_USER)

# Error monitoring (optional — Sentry is a no-op without a DSN)
SENTRY_DSN=""

# Public origin of THIS backend (used to build absolute URLs for uploaded
# images). Defaults to http://localhost:<PORT>. In prod: https://api.baghaei.com
APP_PUBLIC_URL=""

# Observability
SERVICE_NAME="baghaei-backend"
SERVICE_VERSION="1.0.0"
JAEGER_HOST="localhost"
